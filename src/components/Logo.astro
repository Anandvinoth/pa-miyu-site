---
import { Image } from 'astro:assets';
import sealLight from '../assets/miyu.png';
import sealDark from '../assets/miyu.png';

interface Props {
  class?: string;
}
const { class: className } = Astro.props;
const base = className ? `${className} ` : '';
---

{/* Both variants are rendered; CSS shows the one matching the active theme. */}
<Image
  class={`${base}brand__mark--light`}
  src={sealLight}
  alt=""
  widths={[200, 400, 600]}
  sizes="(max-width: 1023px) 118px, 158px"
  loading="eager"
  aria-hidden="true"
/>
<Image
  class={`${base}brand__mark--dark`}
  src={sealDark}
  alt=""
  widths={[200, 400, 600]}
  sizes="(max-width: 1023px) 118px, 158px"
  loading="eager"
  aria-hidden="true"
/>
